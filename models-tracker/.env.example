# ═══════════════════════════════════════════════════════════
# AI Models Tracker - 环境变量配置
# 复制为 .env 后填入真实值（.env 不要提交到 git）
# ═══════════════════════════════════════════════════════════

# === 字段分类模型（高频/便宜，用于 14 列字段分类）===
# 推荐用阿里百炼（dashscope），模型用 qwen-plus 等便宜模型
TRACKER_FIELD_API_KEY=sk-5ed802d9d00b4822a8fb312b061b1230
TRACKER_FIELD_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TRACKER_FIELD_MODEL=qwen-plus

# === 备注浓缩模型（高推理/最强，用于多源软信息浓缩成一句话）===
# 推荐用 kuai 接外部强模型如 Claude-4.6-Opus
TRACKER_NOTE_API_KEY=sk-8eivavdWOmtjfaG9mk1U3l9o0BTRXmQMeVZYl5XF98TQeL2A
TRACKER_NOTE_API_BASE=https://api.kuai.host/v1
TRACKER_NOTE_MODEL=claude-4.6-opus

# === 钉钉推送（测试群）===
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
# DINGTALK_SECRET=SECyour-secret

# === 钉钉推送（正式群，JSON 数组）===
# DINGTALK_TEXT_GROUPS=[{"name":"AI模型追踪群","webhook":"https://...","secret":"SEC..."}]

# === ZeroEval API（多模态排行榜，公开接口可不填）===
# ZEROEVAL_API_BASE=https://api.zeroeval.com

# === 代理（可选，国内环境抓取国外 RSS 时使用）===
# TRACKER_PROXY=http://127.0.0.1:7897

# === SSL 证书验证（公司网络代理环境可能需要跳过）===
# TRACKER_SKIP_SSL_VERIFY=true

# === GitHub Pages 站点 URL（生成钉钉链接时使用）===
# 未配置时使用本地 file:// 链接
TRACKER_SITE_URL=https://yqiu07.github.io/ai-models-tracker-site
