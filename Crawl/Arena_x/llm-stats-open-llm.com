entColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M69.0152 1.78621C72.4092 -0.170924 76.5908 -0.170924 79.9848 1.78621L135.515 33.8081C138.909 35.7652 141 39.3822 141 43.2965V107.34C141 111.254 138.909 114.871 135.515 116.829L79.9848 148.85C76.5908 150.808 72.4092 150.808 69.0152 148.85L13.4848 116.829C10.0909 114.871 8 111.254 8 107.34V43.2965C8.00006 39.3822 10.0909 35.7652 13.4848 33.8081L69.0152 1.78621ZM130.03 49.3692C130.03 46.6702 127.105 44.9836 124.765 46.333L76.2547 74.3062C75.1687 74.9324 74.4996 76.0898 74.4996 77.3423V133.289C74.4996 135.988 77.4248 137.675 79.765 136.325L128.275 108.352C129.361 107.726 130.03 106.568 130.03 105.316V49.3692Z"></path><path d="M115.746 79.2627C115.746 85.3138 113.781 90.2192 111.358 90.2192C108.935 90.2192 106.97 85.3138 106.97 79.2627C106.97 73.2117 108.935 68.3063 111.358 68.3063C113.781 68.3063 115.746 73.2117 115.746 79.2627Z"></path><path d="M100.827 87.1514C100.827 93.2024 98.8626 98.1078 96.4393 98.1078C94.0159 98.1078 92.0514 93.2024 92.0514 87.1514C92.0514 81.1003 94.0159 76.195 96.4393 76.195C98.8626 76.195 100.827 81.1003 100.827 87.1514Z"></path></svg><span class="text-[11px] font-medium uppercase tracking-[0.14em] text-[#71717a]" style="font-family:var(--font-callingbox-mono)">CallingBox</span></div><p class="mt-5 text-[30px] font-semibold leading-[1.05] tracking-[-0.04em] text-[#f4f4f5] sm:text-[36px]">The hard part isn&#x27;t the model. It&#x27;s the phone stack.</p><p class="mt-4 max-w-[420px] text-[15px] leading-[1.7] text-[#a1a1aa]">Telephony, STT, TTS, and orchestration in one API</p><div class="mt-7 flex flex-wrap items-center gap-3"><a href="https://callingbox.io/?utm_source=llm-stats&amp;utm_medium=promo_card&amp;utm_campaign=open-llm-leaderboard&amp;utm_content=lg" target="_blank" rel="noopener" class="rounded-full bg-[#f4f4f5] px-7 py-2.5 text-[14px] font-medium text-[#18181b] transition-colors hover:bg-[#d4d4d8] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa]">Start for free</a><a href="https://docs.callingbox.io" target="_blank" rel="noopener" class="rounded-full border border-[#3f3f46] px-7 py-2.5 text-[14px] font-medium text-[#a1a1aa] transition-colors hover:border-[#52525b] hover:text-[#f4f4f5] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa]">Read the docs</a></div><div class="mt-7 flex items-center gap-5 text-[13px] text-[#52525b]"><span><span class="font-medium text-[#a1a1aa]">$0.05</span> /min all-in</span><span aria-hidden="true" class="h-3.5 w-px bg-[#27272a]"></span><span><span class="font-medium text-[#a1a1aa]">7 lines</span> of code</span></div></div><div class="min-w-0"><style>
@keyframes cb-scan {
  0%   { transform: translateY(-12%); opacity: 0; }
  12%  { opacity: 1; }
  88%  { opacity: 1; }
  100% { transform: translateY(112%); opacity: 0; }
}
@keyframes cb-breath {
  0%, 100% { opacity: 0.35; }
  50%      { opacity: 1; }
}
@keyframes cb-ping {
  0%   { transform: scale(1);   opacity: 0.55; }
  100% { transform: scale(2.6); opacity: 0; }
}
@keyframes cb-draw {
  from { stroke-dashoffset: 1; }
  to   { stroke-dashoffset: 0; }
}
@keyframes cb-rise {
  from { transform: translateY(6px); opacity: 0; }
  to   { transform: translateY(0);   opacity: 1; }
}
@keyframes cb-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes cb-orbit-x {
  0%   { left: 0%;                opacity: 0; }
  15%  { opacity: 1; }
  85%  { opacity: 1; }
  100% { left: calc(100% - 6px);  opacity: 0; }
}
.cb-scan      { animation: cb-scan 1.0s cubic-bezier(0.32, 0, 0.32, 1) both; }
.cb-breath    { animation: cb-breath 2.4s ease-in-out infinite; }
.cb-ping      { animation: cb-ping 1.8s cubic-bezier(0.32, 0, 0.32, 1) infinite; }
.cb-draw      { stroke-dasharray: 1; animation: cb-draw 0.7s cubic-bezier(0.32, 0, 0.32, 1) both; }
.cb-rise      { animation: cb-rise 0.5s cubic-bezier(0.22, 1, 0.36, 1) both; }
.cb-fade-in   { animation: cb-fade-in 0.45s ease both; }
.cb-orbit     { animation: cb-orbit-x 1.4s linear infinite; }
@media (prefers-reduced-motion: reduce) {
  .cb-scan, .cb-breath, .cb-ping, .cb-draw, .cb-rise, .cb-fade-in, .cb-orbit {
    animation: none !important;
  }
}
</style><div class="rounded-2xl bg-[#1f1f23] ring-1 ring-[#27272a]"><div class="flex items-center px-4 pt-2.5 pb-0"><div class="mr-5 flex items-center gap-1.5"><span class="h-[9px] w-[9px] rounded-full bg-white/[0.06]"></span><span class="h-[9px] w-[9px] rounded-full bg-white/[0.06]"></span><span class="h-[9px] w-[9px] rounded-full bg-white/[0.06]"></span></div><div class="flex"><button type="button" class="relative px-3.5 py-1.5 text-[12px] font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa] text-[#a1a1aa]">Python<span class="absolute bottom-0 left-3 right-3 h-px bg-[#3f3f46]"></span></button><button type="button" class="relative px-3.5 py-1.5 text-[12px] font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa] text-[#3f3f46] hover:text-[#71717a]">TypeScript</button><button type="button" class="relative px-3.5 py-1.5 text-[12px] font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa] text-[#3f3f46] hover:text-[#71717a]">cURL</button><button type="button" class="relative px-3.5 py-1.5 text-[12px] font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a1a1aa] text-[#3f3f46] hover:text-[#71717a]">CLI</button></div></div><div class="mx-1 mt-1 mb-1 rounded-b-2xl bg-[#1c1c20]"><div class="relative overflow-hidden px-6 py-5 text-[13px] leading-[2.1] whitespace-pre" style="font-family:var(--font-callingbox-mono)"><div class="text-[#71717a]"><span class="text-[#c4b5fd]">from</span> <span class="text-[#d4d4d8]">callingbox</span> <span class="text-[#c4b5fd]">import</span> <span class="text-[#d4d4d8]">Callingbox</span></div><div class="h-3"></div><div class="text-[#71717a]"><span class="text-[#d4d4d8]">client</span> <span class="text-[#52525b]">=</span> <span class="text-[#d4d4d8]">Callingbox</span><span class="text-[#52525b]">()</span></div><div class="h-3"></div><div class="text-[#71717a]"><span class="text-[#d4d4d8]">call</span> <span class="text-[#52525b]">=</span> <span class="text-[#d4d4d8]">client</span><span class="text-[#52525b]">.</span><span class="text-[#d4d4d8]">calls</span><span class="text-[#52525b]">.</span><span class="text-[#93c5fd]">create</span><span class="text-[#52525b]">(</span></div><div class="text-[#71717a]">    <span class="text-[#93c5fd]">agent_id</span><span class="text-[#52525b]">=</span><span class="text-[#86efac]">&quot;agt_7f3a...&quot;</span><span class="text-[#52525b]">,</span></div><div class="text-[#71717a]">    <span class="text-[#93c5fd]">to</span><span class="text-[#52525b]">=</span><span class="text-[#86efac]">&quot;+15551234567&quot;</span><span class="text-[#52525b]">,</span></div><div class="text-[#71717a]">    <span class="text-[#93c5fd]">context</span><span class="text-[#52525b]">=</span><span class="text-[#52525b]">{</span> <span class="text-[#86efac]">&quot;patient&quot;</span><span class="text-[#52525b]">:</span> <span class="text-[#86efac]">&quot;Maria Lopez&quot;</span> <span class="text-[#52525b]">}</span><span class="text-[#52525b]">,</span></div><div class="text-[#71717a]"><span class="text-[#52525b]">)</span></div></div><div class="border-t border-[#27272a]"><div class="px-6 pt-3.5 pb-4"><div class="flex items-center justify-between text-[11px]" style="font-family:var(--font-callingbox-mono)"><span class="inline-flex items-center gap-2"><span class="relative inline-flex h-1.5 w-1.5"><span class="relative inline-flex h-1.5 w-1.5 rounded-full cb-breath" style="background-color:#52525b"></span></span><span class="uppercase tracking-[0.14em] text-[#a1a1aa]">ready</span></span><span class="cb-fade-in"><span class="text-[#52525b]">idle</span></span></div><div class="mt-3.5 flex items-center gap-3"><div class="relative flex h-9 w-9 shrink-0 items-center justify-center 