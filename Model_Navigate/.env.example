# ============================================
# Model Navigate - 环境变量配置（脱敏参数）
# ============================================
# 复制本文件为 .env 并填入你的 API Key
# cp .env.example .env
#
# 参数分三层管理：
#   .env（本文件）→ API Key、Webhook、Token、API Base URL
#   config.py     → 数据源 URL、超时、UA、数据常量、阈值等
#   各脚本内部    → 不变的核心逻辑
#
# 详细说明见 README.md 的"配置管理"章节

# ── 钉钉日报推送 ──
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=SEC_YOUR_SECRET

# ── 主 LLM API（kuai — 用于 LLM 提取和审核）──
KUAI_API_KEY=sk-xxx
KUAI_API_BASE=https://api.kuai.host/v1
KUAI_MODEL=claude-opus-4-6
REVIEW_MODEL=gpt-5.5

# ── 备选 LLM API（DashScope 百炼 — Qwen，提取失败时 fallback）──
LLM_API_KEY=sk-xxx
# TRACKER_FIELD_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=sk-xxx
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ── HuggingFace（用于开源模型交叉校验，可选）──
# HF_TOKEN=hf_xxx
