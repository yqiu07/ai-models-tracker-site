# ============================================
# Model Navigate - 环境变量配置
# ============================================
# 复制本文件为 .env 并填入你的 API Key
# cp .env.example .env

# ── 钉钉日报推送 ──
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=SEC_YOUR_SECRET

# ── LLM API（用于腾讯研究院文章模型提取，三选一）──
LLM_API_KEY=sk-xxx
# TRACKER_FIELD_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=sk-xxx
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ── GPT-5.5 审核（用于 review_models.py）──
KUAI_API_KEY=sk-xxx
KUAI_API_BASE=https://api.kuai.host/v1
REVIEW_MODEL=gpt-5.5

# ── HuggingFace（用于开源模型交叉校验，可选）──
# HF_TOKEN=hf_xxx
